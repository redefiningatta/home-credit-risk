# Kaggle credentials — legacy format from kaggle.com/settings/api
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# GCP — deployment service account (used by Terraform only)
DEPLOYMENT_SA_CREDENTIALS=credentials/gcp-service-account.json

# GCP — application service account (used by ingestion, dbt, Airflow)
GOOGLE_APPLICATION_CREDENTIALS=credentials/home-credit-app-sa.json
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=home-credit-raw-data-yourname
BIGQUERY_DATASET=raw
